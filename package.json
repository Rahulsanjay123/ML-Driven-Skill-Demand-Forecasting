{
  "name": "ml-skill-forecasting-ultimate",
  "version": "1.0.0",
  "description": "ML-Driven Skill Demand Forecasting Platform",
  "main": "backend/server.js",
  "type": "module",
  "scripts": {
    "install-all": "npm install && npm install --prefix frontend && npm install --prefix backend",
    "dev-backend": "npm run dev --prefix backend",
    "dev-frontend": "npm run dev --prefix frontend",
    "dev-ml": "cd backend/ml-service && python app.py",
    "dev": "concurrently \"npm:dev-backend\" \"npm:dev-frontend\" \"npm:dev-ml\"",
    "start": "node backend/server.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
